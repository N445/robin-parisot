{% import 'macro/actuality-card.html.twig' as actualityMacro %}
{% extends 'base.html.twig' %}
    {%- block title -%}Liste des actualités{%- endblock -%}

{% block body %}
    <div class="container">
        <a href="{{ path('homepage') }}" class="btn btn-gradiant my-3"><i class="fa fa-angle-double-left"></i> Revenir</a>
        <div class="row">
            {% for actuality in actualities %}
                <div class="col-md-4 mb-5">
                    {{ actualityMacro.actualityCard(actuality) }}
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}


