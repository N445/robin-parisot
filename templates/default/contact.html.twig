{% extends 'base.html.twig' %}

{% block title %}Contactez moi - {{ parent() }}{% endblock %}
{% block body %}
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-4">
                <div class="p-4 shadow">
                    {{ form_start(form) }}
                    <div class="mb-3">
                        {{ form_row(form.firstname) }}
                    </div>
                    <div class="mb-3">
                        {{ form_row(form.lastname) }}
                    </div>
                    <div class="mb-3">
                        {{ form_row(form.email) }}
                    </div>
                    <div class="mb-3">
                        {{ form_row(form.subject) }}
                    </div>
                    <div class="mb-3">
                        {{ form_row(form.message) }}
                    </div>
                    <div class="d-grid">
                        <button class="btn btn-primary bg-gradient btn-block" type="submit">
                            Envoyer
                        </button>
                    </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
