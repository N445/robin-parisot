<h2>Contactez moi</h2>
<div class="row justify-content-center mb-5">
    <div class="col-md-6">
        <div class="shadow p-5">
            {{ form_start(form) }}
            <div class="form-row">
                <div class="col-md-6">
                    {{ form_row(form.firstname) }}
                </div>
                <div class="col-md-6">
                    {{ form_row(form.lastname) }}
                </div>
            </div>
            <div class="form-group">
                {{ form_row(form.email) }}
            </div>
            <div class="form-group">
                {{ form_row(form.subject) }}
            </div>
            <div class="form-group">
                {{ form_row(form.message) }}
            </div>
            <button type="submit" class="btn btn-gradiant btn-block">Envoyer</button>
            {{ form_end(form) }}
        </div>
    </div>
</div>