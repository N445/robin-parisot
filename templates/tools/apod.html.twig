{% extends 'base-admin.html.twig' %}

{% block body %}
    <h2>APOD</h2>
    <table class="table table-striped table-hover">
        <thead>
        <th></th>
        <th>
            Title
        </th>
        <th>
            Action
        </th>
        </thead>
        <tbody>
        {% for apod in apods %}
            <tr>
                <td>
                    <img src="{{ apod.url }}" alt="{{ apod.title }}" width="100">
                </td>
                <td class="text-justify">
                    {{ apod.title }}<br>
                    <small>{{ apod.explanation }}</small>
                </td>
                <td>
                    <a href="{{ apod.hdurl }}" target="_blank" class="btn btn-sm btn-info">
                        Voir
                    </a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}